# --- API ---
# Base URL (no trailing slash); the client appends /all-clients-data
API_BASE_URL=https://api.gemalgo.com/api/alpaca-open
# Passed as the `api_code` query-string parameter
API_KEY= %$%^&)(#PS@123456@#@

# --- SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=replace_me
SMTP_USE_TLS=true

# --- Email ---
EMAIL_FROM=reports@example.com
EMAIL_TO=you@example.com

# --- Output ---
OUTPUT_DIR=./out
